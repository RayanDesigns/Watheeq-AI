{
  "name": "watheeq-e2e",
  "version": "0.2.0",
  "private": true,
  "description": "Sprint-based end-to-end tests for Watheeq AI platform",
  "scripts": {
    "test": "npx playwright test",
    "test:sprint1": "npx playwright test --project=sprint1",
    "test:sprint2": "npx playwright test --project=sprint2",
    "test:sprint3": "npx playwright test --project=sprint3",
    "test:sprint4": "npx playwright test --project=sprint4",
    "test:cross-sprint": "npx playwright test --project=cross-sprint",
    "test:smoke": "npx playwright test --project=smoke",
    "test:release": "npx playwright test --project=release",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:mobile": "npx playwright test --project=mobile-chrome",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:tag": "npx playwright test --grep",
    "report": "npx playwright show-report playwright-report",
    "codegen": "npx playwright codegen http://localhost:3000",
    "install:browsers": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
