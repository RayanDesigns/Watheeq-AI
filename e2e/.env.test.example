# Watheeq E2E — copy to `.env.test` in this folder (gitignored). Never commit secrets.
#
# Minimum for admin UI tests: BASE_URL, API_URL, ADMIN_EMAIL, ADMIN_PASSWORD
# (same admin as `python backend/create_admin.py`).
#
# Firebase fields below are optional for current specs; fill them if you add
# token-based setup or scripts that call Firebase Admin from Node.

# ── App (README defaults) ───────────────────────────────────────────────────
BASE_URL=http://localhost:3000
API_URL=http://localhost:8000

# ── Firebase Web — same values as frontend/.env.local ───────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY        → FIREBASE_API_KEY
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN    → FIREBASE_AUTH_DOMAIN
# NEXT_PUBLIC_FIREBASE_PROJECT_ID     → FIREBASE_PROJECT_ID
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# ── Firebase Admin — same as backend/.env (service account) ────────────────
# FIREBASE_PROJECT_ID is duplicated above for clarity; backend also uses:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@....iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Admin login (matches backend/create_admin.py defaults) ─────────────────
ADMIN_EMAIL=admin@watheeq.ai
ADMIN_PASSWORD=Admin@1234

# ── OTP / claimant & examiner flows (Authintica — authentica.sa) ────────────
# Use numbers provisioned in your Authentica project (sandbox/test if available).
TEST_PHONE_CLAIMANT=+966500000001
TEST_PHONE_EXAMINER=+966500000002
