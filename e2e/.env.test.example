# Watheeq E2E — copy to `.env.test` in this folder (gitignored). Never commit secrets.
#
# Minimum for admin UI tests: BASE_URL, API_URL, ADMIN_EMAIL, ADMIN_PASSWORD
# (same admin as `python backend/create_admin.py`).
#
# You do NOT need to copy backend/.env or frontend/.env.local here.
# Those servers load their own env files when Playwright starts them via webServer.
# This file is ONLY for values the Playwright test runner itself needs.

# ── App URLs ─────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
API_URL=http://localhost:8000

# ── Firebase client config (same 3 values from frontend/.env.local) ──────────
# Only needed if E2E tests call Firebase JS SDK directly (e.g., signInWithCustomToken).
# Currently optional — leave blank if not using token-based test setup.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# ── Firebase Admin SDK (for test setup — creating test users/tokens from Node) ─
# Only needed if you add a Node.js setup script that calls Firebase Admin SDK.
# Currently optional — leave blank if not using programmatic user creation.
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Admin test account (created by backend/create_admin.py) ──────────────────
ADMIN_EMAIL=admin@watheeq.ai
ADMIN_PASSWORD=Admin@1234

# ── Test phone numbers ───────────────────────────────────────────────────────
# Use numbers valid in your Authentica test/sandbox environment.
TEST_PHONE_CLAIMANT=+966500000001
TEST_PHONE_EXAMINER=+966500000002
# Second examiner — used for US-17 claim-locking tests (Sprint 2)
TEST_PHONE_EXAMINER_2=+966500000003

# ── OTP Bypass (test environment only) ───────────────────────────────────────
# When the backend runs with WATHEEQ_ENV=test, it accepts this fixed OTP
# instead of calling the Authentica SMS API. Leave blank to use real OTP.
TEST_OTP_CODE=1234

# To set up:
#   cp e2e/.env.test.example e2e/.env.test
#   edit .env.test with real credentials (Firebase keys, etc.)
